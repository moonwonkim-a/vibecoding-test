meta {
  name: TC-ADMIN-LOGIN-005 로그아웃 후 관리자 API 접근
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/admin/books
  body: none
  auth: none
}

assert {
  res.status: eq 401
  res.body.success: eq false
  res.body.errorCode: eq AUTH-001
}

docs {
