meta {
  name: TC-LIST-008 대여 불가 도서 표시
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/books/{{unavailableIsbn}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.availableCount: eq 0
  res.body.data.rentAvailable: eq false
}

docs {
  TC-LIST-008 | FR-LIST-005 | 대여 불가 도서 표시
  기대 결과: availableCount=0, rentAvailable=false
  전제 조건: {{unavailableIsbn}} 도서의 모든 재고가 대여 중인 상태 (목데이터 기준: 9780000000000)
}
