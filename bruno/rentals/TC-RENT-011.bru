meta {
  name: TC-RENT-011 user_code7 형식 오류
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/rentals/check
  body: json
  auth: none
}

body:json {
  {
    "userName": "테스트",
    "userCode7": "123"
  }
}

assert {
  res.status: eq 400
  res.body.success: eq false
}

docs {
  TC-RENT-011 | EX-014 | user_code7 형식 오류
  기대 결과: 400 응답, 요청 실패
  검증: userCode7이 7자리가 아닌 경우 (3자리 입력)
}
