meta {
  name: TC-RENT-012 동일 user_code7에 다른 이름 입력
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/rentals
  body: json
  auth: none
}

body:json {
  {
    "isbn": "{{availableIsbn}}",
    "userName": "다른이름",
    "userCode7": "{{userNormalCode}}"
  }
}

assert {
  res.status: eq 409
  res.body.success: eq false
  res.body.errorCode: eq EX-015
}

docs {
  TC-RENT-012 | EX-015 | 동일 user_code7에 다른 이름 입력
  기대 결과: 409 응답, errorCode=EX-015, 대여 차단
  전제 조건: 홍길동(9001151)이 이미 등록된 이용자 - 다른 이름으로 시도
}
