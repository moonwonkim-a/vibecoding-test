2026-06-05T13:24:10.296+09:00 DEBUG 2740 --- [nio-8080-exec-3] org.hibernate.SQL                        : 
    SELECT
        b.isbn,
        b.title,
        b.author,
        b.publisher,
        b.category,
        b.price,
        COUNT(i.inventory_id) AS total_count,
        SUM(CASE 
            WHEN i.available = true 
                THEN 1 
            ELSE 0 
    END) AS available_count 
FROM
    library_book_info b 
LEFT JOIN
    library_book_inventory i 
        ON b.isbn = i.isbn 
WHERE
    b.isbn = ? 
GROUP BY
    b.isbn,
    b.title,
