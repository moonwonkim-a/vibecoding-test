    SELECT
        b.isbn,
        b.title,
        b.author,
        b.category,
        b.publisher,
        b.price,
        COUNT(i.inventory_id) AS total_count,
        SUM(CASE 
            WHEN i.available = true 
                THEN 1 
            ELSE 0 
    END) AS available_count,
    b.rent_count 
FROM
    library_book_info b 
LEFT JOIN
    library_book_inventory i 
        ON b.isbn = i.isbn 
        AND i.del_yn = 'N' 
WHERE
    b.del_yn = 'N' 
GROUP BY
    b.isbn,
    b.title,
    b.author,
    b.category,
    b.publisher,
    b.price,
    b.rent_count 
ORDER BY
    b.title ASC 
